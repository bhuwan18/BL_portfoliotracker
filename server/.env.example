# Optional: enables Twelve Data as a fallback stock source when Yahoo returns 429/empty.
# Get a free key at https://twelvedata.com (800 req/day). Leave unset to stay fully keyless.
TWELVEDATA_API_KEY=8517b599929244949f33fb3876372e8c

# Port the proxy listens on (default 8787)
PORT=8787

# Optional: durable store for "share via key" (/api/share). Set EITHER the Vercel KV
# pair OR the Upstash pair (they're the same service). When unset, the server uses an
# in-memory fallback that works for local dev only (keys are lost on restart and are
# NOT shared across serverless invocations — so production on Vercel REQUIRES these).
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
